{
    "name": "elvesora/soryxa-php",
    "version": "1.0.0",
    "description": "Pure PHP SDK for the Soryxa email validation API",
    "keywords": ["soryxa", "email", "validation", "php"],
    "license": "MIT",
    "authors": [
        {
            "name": "Elvesora",
            "email": "team@elvesora.com"
        }
    ],
    "type": "library",
    "require": {
        "php": "^8.1",
        "ext-curl": "*",
        "ext-json": "*"
    },
    "autoload": {
        "psr-4": {
            "Elvesora\\SoryxaPHP\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Elvesora\\SoryxaPHP\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
